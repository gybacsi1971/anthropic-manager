# ==========================================================================
# Anthropic Manager — környezeti változók. Másold .env-be és töltsd ki.
# A kötelező változók hiánya esetén a Compose / az alkalmazás HIBÁVAL leáll
# (nincs fallback).
# ==========================================================================

# PostgreSQL jelszó — KÖTELEZŐ. Adj erős, véletlenszerű jelszót.
# Generálás (URL-biztos, csak 0-9a-f — a DATABASE_URL-be kerül):
#   openssl rand -hex 24
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Fernet titkosító kulcs az Admin API kulcsok DB-tárolásához — KÖTELEZŐ.
# Generálás:
#   openssl rand -base64 32 | tr '+/' '-_'
# FIGYELEM: ha megváltoztatod, a meglévő titkosított kulcsok már nem dekódolhatók.
API_KEY_ENCRYPTION_KEY=

# Anthropic Admin API kulcs (sk-ant-admin…) — OPCIONÁLIS, kényelmi import.
# Ha megadod, az első induláskor a backend Fernet-titkosítva beimportálja a DB-be
# (az Admin kulcsok oldalon megjelenik, "ANTHROPIC_ADMIN_KEY" címkével), majd
# innentől a felületen kezelhető. Idempotens: újraindításkor nem duplikálódik.
# Több kulcshoz: ANTHROPIC_ADMIN_KEY_2, ANTHROPIC_ADMIN_KEY_3, …
# FONTOS: a használat/költség/Claude Code végpontok ADMIN kulcsot igényelnek
# (sk-ant-admin…), a sima API kulcs (sk-ant-api…) NEM elég.
ANTHROPIC_ADMIN_KEY=

# Alapértelmezett admin felhasználó — bootstrap.
# Ha megadod, az ELSŐ induláskor (üres adatbázisnál) létrejön ez az admin fiók,
# és rögtön be tudsz lépni vele. Később a felületen módosítható (jelszó-csere),
# a .env-beli értéket onnantól figyelmen kívül hagyja. Üresen hagyva a /setup
# varázsló kéri be az első admint.
# >>> PUBLIKUS INTERNETRE KITETT DEPLOYNÁL KÖTELEZŐ kitölteni <<<
# Így a forgalom-kiszolgálás megkezdésekor már létezik admin, és a /setup
# varázsló (ami auth nélkül elérhető az első user létrejöttéig) NEM vehető át.
# A jelszó min. 12 karakter; publikushoz erős, 16+ karakteres, jelszókezelőből.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-min-12-chars-use-a-password-manager
ADMIN_NAME=Adminisztrátor

# --- PROD (Traefik) — csak a docker-compose.yml-hez kell ------------------
# Traefik router-név és publikus domain. KÖTELEZŐ a PROD compose-hoz.
# Példa:
#   TRAEFIK_ROUTER_NAME=anthropic-manager
#   TRAEFIK_HOST=anthropic-manager.example.com
TRAEFIK_ROUTER_NAME=anthropic-manager
TRAEFIK_HOST=anthropic-manager.example.com

# A dedikált, nem-root Docker-felhasználó UID/GID-je — KÖTELEZŐ a PROD compose-hoz.
# Lekérdezés a hoston:  id -u <docker-user>   és   id -g <docker-user>
HOST_UID=1001
HOST_GID=1001

# Környezet-azonosító badge a fejlécben (opcionális, üresen nem jelenik meg).
# ENV_TYPE:  rövid felirat (pl. PROD, UAT, DEV)
# ENV_COLOR: háttérszín (hex). Pl. PROD piros: #C81E1E
ENV_TYPE=
ENV_COLOR=
